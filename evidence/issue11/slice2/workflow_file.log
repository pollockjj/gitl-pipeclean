name: Slice Evidence Collection

on:
  push:
    branches:
      - 'issue*/slice*'

jobs:
  collect-evidence:
    runs-on: ubuntu-latest
    permissions:
      contents: write
      issues: write

    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: ${{ github.ref }}
          fetch-depth: 0

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Install dependencies
        run: |
          pip install pytest PyJWT cryptography requests

      - name: Parse branch metadata
        id: meta
        run: |
          BRANCH="${GITHUB_REF_NAME}"
          # Extract issue number and slice from branch name: issue{N}/slice{M}...
          ISSUE_NUM=$(echo "$BRANCH" | grep -oP '(?<=issue)\d+')
          SLICE_NUM=$(echo "$BRANCH" | grep -oP '(?<=slice)\d+')
          echo "issue=$ISSUE_NUM" >> $GITHUB_OUTPUT
          echo "slice=$SLICE_NUM" >> $GITHUB_OUTPUT
          echo "evidence_dir=evidence/issue${ISSUE_NUM}/slice${SLICE_NUM}" >> $GITHUB_OUTPUT
          echo "Parsed: issue=$ISSUE_NUM slice=$SLICE_NUM"

      - name: Create evidence directory
        run: mkdir -p ${{ steps.meta.outputs.evidence_dir }}

      - name: Run tests
        run: |
          python -m pytest tests/ -v 2>&1 | tee ${{ steps.meta.outputs.evidence_dir }}/test_run.log
          echo "EXIT_CODE: $?" >> ${{ steps.meta.outputs.evidence_dir }}/test_run.log

      - name: Run fib.py if present
        run: |
          if [ -f fib.py ]; then
            python fib.py 2>&1 | tee ${{ steps.meta.outputs.evidence_dir }}/fib_run.log
          fi

      - name: Generate checksums
        run: |
          cd ${{ steps.meta.outputs.evidence_dir }}
          sha256sum *.log > sha256sums.txt 2>/dev/null || true

      - name: Commit evidence
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add ${{ steps.meta.outputs.evidence_dir }}/
          git commit -m "CI: collect evidence for issue #${{ steps.meta.outputs.issue }} slice ${{ steps.meta.outputs.slice }}" || echo "No changes to commit"
          git push

      - name: Build Phase 4 results
        run: |
          SHA=$(git rev-parse HEAD)
          EVIDENCE_DIR="${{ steps.meta.outputs.evidence_dir }}"
          ISSUE="${{ steps.meta.outputs.issue }}"
          SLICE="${{ steps.meta.outputs.slice }}"
          cat > /tmp/phase4_results.md << RESULTS_EOF
          ## Slice ${SLICE} TDD Results — COMPLETE (CI-collected)

          **Submitted:** $(date -u +"%Y-%m-%dT%H:%M:%SZ")
          **Commit SHA:** ${SHA}
          **Evidence directory:** ${EVIDENCE_DIR}/ @ ${SHA}
          **Collected by:** github-actions[bot] (CI workflow, not agent)

          ### Evidence Manifest

          $(ls -1 ${EVIDENCE_DIR}/ | while read f; do echo "- [E] ${f} — ${EVIDENCE_DIR}/${f}"; done)

          ### Summary

          Evidence collected by CI workflow. Test output, checksums, and logs committed by github-actions[bot]. Agent did not run tests or commit evidence.
          RESULTS_EOF

      - name: Post results to issue
        env:
          GITL_TDD_APP_ID: ${{ secrets.GITL_TDD_APP_ID }}
          GITL_TDD_INSTALL_ID: ${{ secrets.GITL_TDD_INSTALL_ID }}
          GITL_TDD_PEM: ${{ secrets.GITL_TDD_PEM }}
        run: |
          ISSUE="${{ steps.meta.outputs.issue }}"
          # Write PEM to temp file
          echo "$GITL_TDD_PEM" > /tmp/gitl-tdd.pem
          # Generate JWT and post
          python3 - << 'PYEOF'
          import jwt, time, requests, sys, os

          pem = open("/tmp/gitl-tdd.pem").read()
          app_id = os.environ["GITL_TDD_APP_ID"]
          install_id = os.environ["GITL_TDD_INSTALL_ID"]

          now = int(time.time())
          token = jwt.encode({"iat": now - 60, "exp": now + 540, "iss": app_id}, pem, algorithm="RS256")
          h = {"Authorization": f"Bearer {token}", "Accept": "application/vnd.github+json"}
          r = requests.post(f"https://api.github.com/app/installations/{install_id}/access_tokens", headers=h)
          r.raise_for_status()
          access_token = r.json()["token"]

          body = open("/tmp/phase4_results.md").read()
          issue = os.environ.get("ISSUE", sys.argv[1] if len(sys.argv) > 1 else "11")
          h2 = {"Authorization": f"Bearer {access_token}", "Accept": "application/vnd.github+json"}
          r2 = requests.post(
              f"https://api.github.com/repos/{os.environ.get('GITHUB_REPOSITORY', 'pollockjj/gitl-pipeclean')}/issues/{issue}/comments",
              headers=h2,
              json={"body": body},
          )
          r2.raise_for_status()
          print(f"Posted: {r2.json()['html_url']}")
          PYEOF

      - name: Cleanup
        if: always()
        run: rm -f /tmp/gitl-tdd.pem
